FLASK_ENV=development
SECRET_KEY=cambia-esto-en-produccion
JWT_SECRET_KEY=cambia-jwt-en-produccion
# Con `docker compose`, PostgreSQL se publica en el host en el puerto 5433 (ver README).
DATABASE_URL=postgresql+psycopg://eps_user:eps_pass@localhost:5433/eps_db
# Orígenes CORS (coma-separados). Incluye la URL del front en pruebas.
# ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
